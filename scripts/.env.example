# AutoDevOps Agent — 環境変数設定例
# このファイルを .env にコピーして値を設定してください
# .env は .gitignore に追加してコミットしないこと！

# ============================================================
# [必須] Google Cloud プロジェクトID
# GCPコンソールのプロジェクト一覧から確認できます
# ============================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ============================================================
# [任意] Vertex AI のリージョン（デフォルト: us-central1）
# Gemini が利用可能なリージョン: us-central1, asia-northeast1 など
# ============================================================
VERTEX_AI_LOCATION=us-central1

# ============================================================
# [任意] 使用するGeminiモデル（デフォルト: gemini-2.0-flash-001）
# 選択肢:
#   - gemini-2.0-flash-001     （高速・低コスト、推奨）
#   - gemini-1.5-pro-002       （高精度、大きなコンテキスト）
#   - gemini-2.5-pro-preview-05-06  （最高精度）
# ============================================================
GEMINI_MODEL=gemini-2.0-flash-001
